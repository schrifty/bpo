[
  {
    "Name": "bpo-engineering-portfolio-nightly",
    "Description": "Engineering portfolio deck — daily 02:00 UTC",
    "ScheduleExpression": "cron(0 2 * * ? *)",
    "State": "ENABLED",
    "Targets": [
      {
        "Id": "bpo-eng-portfolio",
        "Arn": "arn:aws:ecs:REGION:ACCOUNT_ID:cluster/bpo",
        "RoleArn": "arn:aws:iam::ACCOUNT_ID:role/bpo-eventbridge-ecs",
        "EcsParameters": {
          "TaskDefinitionArn": "arn:aws:ecs:REGION:ACCOUNT_ID:task-definition/bpo-decks",
          "LaunchType": "FARGATE",
          "PlatformVersion": "LATEST",
          "NetworkConfiguration": {
            "awsvpcConfiguration": {
              "Subnets": ["subnet-REPLACE"],
              "SecurityGroups": ["sg-REPLACE"],
              "AssignPublicIp": "DISABLED"
            }
          },
          "TaskCount": 1
        },
        "Input": "{\"containerOverrides\":[{\"name\":\"bpo-decks\",\"command\":[\"engineering-portfolio\"]}]}"
      }
    ]
  },
  {
    "Name": "bpo-portfolio-batch-nightly",
