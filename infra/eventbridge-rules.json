[
  {
    "Name": "decks-engineering-portfolio",
    "Description": "Engineering portfolio deck — daily 01:00 UTC",
    "ScheduleExpression": "cron(0 1 * * ? *)",
    "State": "ENABLED",
    "Targets": [
      {
        "Id": "decks-engineering-portfolio",
        "Arn": "arn:aws:ecs:REGION:ACCOUNT_ID:cluster/cortex",
        "RoleArn": "arn:aws:iam::ACCOUNT_ID:role/cortex-eventbridge-ecs",
        "EcsParameters": {
          "TaskDefinitionArn": "arn:aws:ecs:REGION:ACCOUNT_ID:task-definition/cortex-decks",
          "LaunchType": "FARGATE",
          "PlatformVersion": "LATEST",
          "NetworkConfiguration": {
            "awsvpcConfiguration": {
              "Subnets": ["subnet-REPLACE"],
              "SecurityGroups": ["sg-REPLACE"],
              "AssignPublicIp": "DISABLED"
            }
          },
          "TaskCount": 1
        },
        "Input": "{\"containerOverrides\":[{\"name\":\"cortex-decks\",\"command\":[\"engineering-portfolio\"]}]}"
      }
    ]
  },
  {
