# Copy to terraform.tfvars and adjust. Do NOT commit terraform.tfvars (gitignored).

aws_region   = "us-east-1"
name_prefix  = "cortex"
environment  = "prod"

# Default VPC + all its subnets (assign_public_ip=true for internet without NAT)
use_default_vpc  = true
assign_public_ip = true

# Upload secrets from local builder (repo root):
#   python3 scripts/build_secrets_manager_json.py
# secrets_json_file = "../../output/cortex-secrets-manager.json"

image_tag           = "latest"
default_job_command = ["engineering-portfolio"]

# Set true after first successful manual run-task
enable_schedules = false

# task_cpu    = 4096
# task_memory = 16384
