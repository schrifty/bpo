# Copy to .env and fill in values. Defaults live in src/config.py unless noted.

# --- Logging ---
# LOG_LEVEL=INFO
# CORTEX_LOG_FORMAT=text
# On ECS/Fargate JSON logging is selected automatically unless overridden.

# --- AWS / scheduled runs ---
# AWS resource names use name_prefix from infra/terraform/terraform.tfvars (default: cortex).
# Code/env branding is CORTEX_*; CLI is cortex.
# CORTEX_SKIP_DOTENV=1
# CORTEX_SECRETS_ARN=arn:aws:secretsmanager:REGION:ACCOUNT:secret:cortex/prod/env
# CORTEX_JOB=nightly-core
# CORTEX_FAIL_ON_INTEGRATION_WARNINGS=false
# Support deck: set true to build with empty Jira placeholders when API fetch fails (default: fail loud).
# CORTEX_SUPPORT_JIRA_ALLOW_FALLBACK=false
# CORTEX_JOB_TIMEOUT_SECONDS=7200
# CORTEX_FAILURES_JSON_LOCAL=1
CORTEX_SCHEDULE_NAME_PREFIX=cortex
CORTEX_ECS_CLUSTER=cortex
CORTEX_ECS_TASK_FAMILY=cortex-decks
CORTEX_AWS_REGION=us-east-1

# --- Local / AWS disk cache (GitHub, Cursor, etc.; default: repo .cache/) ---
# CORTEX_CACHE_DIR=/var/cortex/cache

# --- Pendo ---
PENDO_INTEGRATION_KEY=
# PENDO_BASE_URL=https://app.pendo.io/api/v1
# PENDO_MAX_RESULTS=0
# PENDO_MAX_OUTPUT_CHARS=0
# CORTEX_PORTFOLIO_EXCLUDE_CUSTOMERS=ExampleNonCustomer
# CORTEX_PORTFOLIO_PARALLEL_WORKERS=8
# CORTEX_PORTFOLIO_CUSTOMER_SOURCE=auto
# CORTEX_PENDO_CACHE_TTL_SECONDS=120
# CORTEX_PENDO_CACHE_DISABLED=true
# CORTEX_PENDO_DISK_CACHE_TTL_HOURS=12
# CORTEX_PENDO_DISK_CACHE_DISABLED=false
# CORTEX_JIRA_CACHE_TTL_HOURS=20
# CORTEX_JIRA_CACHE_DISABLED=false
# CORTEX_PENDO_ROSTER_MAX_USERS=0
# CORTEX_PENDO_SITE_USERS_CAP=50
# Pendo aggregation request pacing (token bucket). Sustained cap per minute (0 disables
# pacing) plus a burst allowance for parallel fan-out like preload().
# CORTEX_PENDO_MAX_REQUESTS_PER_MINUTE=120
# CORTEX_PENDO_MAX_BURST=32
# CORTEX_PORTFOLIO_SNAPSHOT_FOLDER_ID=
# CORTEX_PORTFOLIO_SNAPSHOT_CALENDAR_TZ=America/New_York

# --- Google (Drive, Slides, QBR, hydrate) ---
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GOOGLE_DRIVE_OWNER_EMAIL=
GOOGLE_QBR_GENERATOR_FOLDER_ID=
# GOOGLE_QBR_TEMPLATE_FOLDER_ID=
# QBR_TEMPLATE_FILE_NAME=BPO [Template] Executive Business Review [QBR]
# GOOGLE_QBR_OUTPUT_PARENT_ID=
GOOGLE_HYDRATE_INTAKE_GROUP=
# HYDRATE_MAX_SLIDES=10
# HYDRATE_REMOVE_INTAKE_GROUP_PERMISSION=true
# CORTEX_MATCHING_LOG=1
# CORTEX_MATCHING_LOG_PATH=

# --- Jira & Atlassian Teams ---
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
# JIRA_AUTH_MODE=site
# JIRA_CLOUD_ID=
# JIRA_CLOUD_ID_AUTO=true
# JIRA_SERVICE_ACCOUNT_AUTH=bearer
ATLASSIAN_ORG_ID=
# ATLASSIAN_API_KEY=

# --- GitHub ---
# GITHUB_TOKEN=
# GITHUB_ORG=your-org
# GITHUB_REPOS=your-org/web-app,other-repo
# GITHUB_API_BASE_URL=https://api.github.com
# CORTEX_GITHUB_LOOKBACK_DAYS=30
# CORTEX_GITHUB_MAX_REPOS=10
# CORTEX_GITHUB_MAX_COMMITS_PER_REPO=500
# CORTEX_GITHUB_CACHE_TTL_HOURS=1
# CORTEX_GITHUB_CACHE_DISABLED=false

# --- Cursor ---
# CURSOR_ADMIN_API_KEY=
# CURSOR_API_BASE_URL=https://api.cursor.com
# CORTEX_CURSOR_CACHE_TTL_HOURS=1
# CORTEX_CURSOR_CACHE_DISABLED=false
# CORTEX_ATLASSIAN_TEAMS_CACHE_TTL_HOURS=1
# CORTEX_ATLASSIAN_TEAMS_CACHE_DISABLED=false
# Build only Cursor slides (engineering-portfolio). Skips Jira *portfolio* fetch and
# GitHub/AI productivity blobs — not the Atlassian Teams call used to scope dev-* engineers.
# cursor_efficiency loses its optional GitHub commits footnote without ai_productivity.
# CORTEX_CURSOR_SLIDES_ONLY=true

# --- Slack ---
# SLACK_BOT_TOKEN=
# SLACK_API_BASE_URL=https://slack.com/api
# CORTEX_SLACK_DISABLED=false
# CORTEX_SLACK_AUTO_JOIN_PUBLIC_CHANNELS=true
#   Join matched public channels before history (requires channels:join bot scope).
# CORTEX_SLACK_LOOKBACK_DAYS=30
# CORTEX_SLACK_MAX_CHANNELS_PER_CUSTOMER=5
# CORTEX_SLACK_MAX_MESSAGES_PER_CHANNEL=50
# Portfolio LLM export Slack (export-all §4b pilot — default top 10 by ARR, 6-month history):
# CORTEX_LLM_EXPORT_SLACK_TOP_N=10
# CORTEX_LLM_EXPORT_SLACK_LOOKBACK_DAYS=180
# CORTEX_LLM_EXPORT_SLACK_MAX_MESSAGES_PER_CHANNEL=2000
# CORTEX_LLM_EXPORT_SLACK_LLM=true
# CORTEX_LLM_EXPORT_SLACK_LLM_ALLOW_FALLBACK=false

# --- Salesforce ---
# Setup: docs/SETUP/SALESFORCE_SETUP.md
SF_LOGIN_URL=https://login.salesforce.com
SF_CONSUMER_KEY=
SF_USERNAME=
SF_PRIVATE_KEY_PATH=server.key
# SF_PRIVATE_KEY=
# SF_ACCOUNT_ULTIMATE_PARENT_LOOKUP=
# SF_ACCOUNT_FACTORY_START_DATE_FIELD=Effective_Date_of_Order__c
# CORTEX_SALESFORCE_CACHE_TTL_HOURS=48
# CORTEX_SALESFORCE_CACHE_DISABLED=true

# --- LLM ---
# gemini | openai (defaults to gemini when GEMINI_API_KEY is set)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- QBR / signals (optional) ---
# CORTEX_FEATURE_ADOPTION_INSIGHTS=true
# CORTEX_SUPPORT_NOTABLE_LLM=true
# CORTEX_SIGNALS_LLM=true
# CORTEX_SIGNALS_LLM_MAX_ITEMS=10
# CORTEX_QBR_MAPPINGS_WRITE=1
# CORTEX_QBR_MAPPINGS_AUTOWRITE=true
# CORTEX_SIGNALS_LLM_EDITORIAL=true
# CORTEX_SIGNALS_LLM_DECK_PROMPT=true
# CORTEX_SIGNALS_LLM_MANIFEST_MAX_CHARS=8000
# CORTEX_SIGNALS_LLM_SLIDE_PROMPT_MAX_CHARS=2500
# CORTEX_SIGNALS_TRENDS=true
# CORTEX_SIGNALS_TRENDS_PRIOR_PERIOD=false
# CORTEX_SIGNALS_TRENDS_WOW=true
# CORTEX_SIGNALS_TRENDS_MOM=false
# CORTEX_SIGNALS_TRENDS_YOY=false
# CORTEX_SIGNALS_TRENDS_TIMEOUT=75

# --- LLM export (cortex export-all) ---
# Primary budget is the LLM token window (cl100k_base). 0 = no token cap.
# CORTEX_LLM_EXPORT_MAX_TOKENS=450000
# Include Pendo usage-by-site in portfolio export-all §1 (default on; set false to skip).
# CORTEX_LLM_EXPORT_USAGE_BY_SITE=true
# Top-ARR customers to include CS Report slices for (default 100 ≈ all; clamp 500).
# CORTEX_LLM_EXPORT_CSR_TOP_N=50
# CORTEX_LLM_EXPORT_JIRA_TOP_N=20
# CORTEX_LLM_EXPORT_JIRA_WORKERS=4
# CORTEX_LLM_EXPORT_JIRA_CUSTOMER_TIMEOUT_SECONDS=120
# CORTEX_LLM_EXPORT_RISK_CUSTOMER_CAP=40
# CORTEX_LLM_EXPORT_RISK_BATCH_SIZE=10
# CORTEX_LLM_EXPORT_SF_COMPREHENSIVE=true
# CORTEX_LLM_EXPORT_SF_COMPREHENSIVE_ROW_LIMIT=8
# CORTEX_LLM_EXPORT_SF_COMPREHENSIVE_CUSTOMER_CAP=12
# CORTEX_LLM_EXPORT_SLACK=true
# CORTEX_LLM_EXPORT_SLACK_TOP_N=10
# CORTEX_INTEGRATION_DRIVE_CACHE_DISABLED=false
# CORTEX_INTEGRATION_DRIVE_CACHE_FORCE_REFRESH=false

# --- LeanDNA Data API ---
# Setup: docs/SETUP/LEANDNA_SETUP.md
# EXECUTION_ENV=Staging | Production | CI (unset = legacy unprefixed vars)
# CORTEX_ALLOW_PRODUCTION_MUTATIONS=true
#
# Staging (EXECUTION_ENV=Staging):
# ST_LEANDNA_DATA_API_BASE_URL=https://app.staging.leandna.com/api
# ST_LEANDNA_DATA_API_BEARER_TOKEN=
# ST_LEANDNA_DATA_API_COOKIE=
# ST_LEANDNA_DATA_API_ORIGIN=https://app.staging.leandna.com
# ST_LEANDNA_DATA_API_REFERER=https://app.staging.leandna.com/application/
#
# Production / CI (EXECUTION_ENV=Production):
# PR_LEANDNA_DATA_API_BASE_URL=https://app.leandna.com/api
# PR_LEANDNA_DATA_API_BEARER_TOKEN=
# PR_LEANDNA_DATA_API_COOKIE=
# PR_LEANDNA_DATA_API_ORIGIN=https://app.leandna.com
# PR_LEANDNA_DATA_API_REFERER=https://app.leandna.com/application/
#
# Legacy (EXECUTION_ENV unset):
# LEANDNA_DATA_API_BASE_URL=https://app.leandna.com/api
# LEANDNA_DATA_API_BEARER_TOKEN=
# LEANDNA_DATA_API_COOKIE=
# LEANDNA_DATA_API_ORIGIN=https://app.leandna.com
# LEANDNA_DATA_API_REFERER=https://app.leandna.com/application/
# LEANDNA_ITEM_MASTER_CACHE_TTL_HOURS=24
# LEANDNA_SHORTAGE_CACHE_TTL_HOURS=12
# LEANDNA_LEAN_PROJECTS_CACHE_TTL_HOURS=24

# --- Advanced (optional) ---
# CORTEX_SLIDES_WRITE_INTERVAL_SEC=1.05
# CORTEX_SLIDES_BATCH_UPDATE_RETRIES=12
# CORTEX_SLIDES_BATCH_CHUNK_SIZE=2000
# CORTEX_JIRA_PARALLEL_WORKERS=3
# CORTEX_JSM_ORG_CACHE_TTL_S=900
# CORTEX_HELP_JIRA_BODY_MAX=750
# CORTEX_HELP_JIRA_METRICS_MAX=2000
# CORTEX_JIRA_SKIP_JSM_ORG_FUZZY=true
# CORTEX_CYCLE_TIME_EXCLUDE_ISSUE_TYPES=Epic,Hypercare
# CORTEX_CYCLE_TIME_OUTLIER_SIGMA=4
