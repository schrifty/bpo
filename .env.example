# Pendo API
PENDO_INTEGRATION_KEY=

# LLM — set one or both keys; use LLM_PROVIDER to choose (gemini or openai).
# Defaults to gemini if GEMINI_API_KEY is set, otherwise openai.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# Google
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GOOGLE_DRIVE_FOLDER_ID=
# Your Google email (folder owner) - enables domain-wide delegation so files use your quota
GOOGLE_DRIVE_OWNER_EMAIL=
# Intake Google Group address — must match Share dialog (Viewer or Editor)
GOOGLE_HYDRATE_INTAKE_GROUP=
# After hydrate: remove the intake group's Drive permission from the **source** deck (default true)
# HYDRATE_REMOVE_INTAKE_GROUP_PERMISSION=true
# Hydrate: max slides per deck (default 10). Set to 0 for no limit.
# `decks --scan-fields` uses the same cap unless SCAN_MAX_SLIDES is set below.
HYDRATE_MAX_SLIDES=10
# Optional: override scan-only slide cap (0 = scan all slides). If unset, HYDRATE_MAX_SLIDES applies.
# SCAN_MAX_SLIDES=0

# JIRA Cloud (read-only)
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# Salesforce (JWT Bearer Flow — optional)
# SF_LOGIN_URL: https://login.salesforce.com (prod) or https://test.salesforce.com (sandbox)
# SF_CONSUMER_KEY: Connected App Consumer Key (Client ID)
# SF_CONSUMER_SECRET: Connected App Consumer Secret
# SF_USERNAME: Integration user username
# SF_PRIVATE_KEY_PATH: path to server.key (or use SF_PRIVATE_KEY with PEM string inline)
SF_LOGIN_URL=https://login.salesforce.com
SF_CONSUMER_KEY=
SF_CONSUMER_SECRET=
SF_USERNAME=
SF_PRIVATE_KEY_PATH=server.key
# SF_PRIVATE_KEY=
