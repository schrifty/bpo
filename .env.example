# Pendo API
PENDO_INTEGRATION_KEY=

# Optional Pendo overrides (defaults in src/config.py)
# PENDO_BASE_URL=https://app.pendo.io/api/v1
# PENDO_MAX_RESULTS=0
# PENDO_MAX_OUTPUT_CHARS=0
# Feature Adoption slide: half-over-half usage narrative (extra Pendo calls). Off by default.
# BPO_FEATURE_ADOPTION_INSIGHTS=true
# Notable Signals: LLM pass to prioritize/merge heuristic + cross-source lines (after Phase 1 rules). Off by default.
# BPO_SIGNALS_LLM=true
# BPO_SIGNALS_LLM_MAX_ITEMS=10

# LLM (required for agent)
# Set one or both keys; use LLM_PROVIDER to choose (gemini or openai).
# Defaults to gemini if GEMINI_API_KEY is set, otherwise openai.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# Google — Slides/Drive (service account + optional impersonation)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GOOGLE_DRIVE_FOLDER_ID=
# Your Google email (folder owner) — domain-wide delegation; files can use your quota
GOOGLE_DRIVE_OWNER_EMAIL=
# Intake Google Group — hydrate/evaluate list Slides shared with this group
GOOGLE_HYDRATE_INTAKE_GROUP=
# QBR: "BPO > QBR Generator" — template deck + Prompts/Manifest (SA: Viewer on template, Editor on output parent)
GOOGLE_QBR_GENERATOR_FOLDER_ID=
# Parent for `{ISO-date} - Output` (optional; defaults to GOOGLE_DRIVE_FOLDER_ID)
GOOGLE_QBR_OUTPUT_PARENT_ID=

HYDRATE_MAX_SLIDES=10
# After hydrate: remove intake group from the source deck (default true)
# HYDRATE_REMOVE_INTAKE_GROUP_PERMISSION=true
# decks --scan-fields: override slide cap (0 = all). If unset, HYDRATE_MAX_SLIDES applies.
# SCAN_MAX_SLIDES=0

# Optional logging
# LOG_LEVEL=INFO

# JIRA Cloud (read-only)
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# Salesforce — JWT Bearer (Connected App + integration user + private key)
# Loaded by src/config.py: SF_LOGIN_URL, SF_CONSUMER_KEY, SF_USERNAME, and SF_PRIVATE_KEY or SF_PRIVATE_KEY_PATH
SF_LOGIN_URL=https://login.salesforce.com
SF_CONSUMER_KEY=
SF_USERNAME=
SF_PRIVATE_KEY_PATH=server.key
# SF_PRIVATE_KEY=

# Connected App labels (not read by BPO; optional for your own notes / external tools)
# SF_APP_NAME=
# SF_CONSUMER_SECRET=
# SF_CALLBACK_URL=https://login.salesforce.com/services/oauth2/success
