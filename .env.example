# Pendo API (required). Powers customer health + QBR: engagement, sites, benchmarks, champions,
# Notable Signals inputs, portfolio snapshot JSON, and related Pendo-backed slides.
PENDO_INTEGRATION_KEY=

# --- Optional Pendo / signals tuning (defaults in src/config.py) ---
# API base URL; only change for non-standard Pendo hosts.
# PENDO_BASE_URL=https://app.pendo.io/api/v1
# Advanced: numeric caps stored in config (0 = no limit). Not wired into the Pendo deck client yet.
# PENDO_MAX_RESULTS=0
# PENDO_MAX_OUTPUT_CHARS=0

# Feature adoption: extra Pendo aggregations for half-over-half style narrative. Sets
# report.feature_adoption_insights — used on the Feature Adoption slide, cross-source signals, and LLM context. Off unless true.
# BPO_FEATURE_ADOPTION_INSIGHTS=true

# Notable Signals LLM: after heuristics + cross-source merge, rewrites/prioritizes report.signals.
# Output is the numbered bullets on the "Notable Signals" slide (and related speaker notes). Off unless true.
# BPO_SIGNALS_LLM=true
# Hard cap on bullet lines the model may return (clamped 3–15 in config).
# BPO_SIGNALS_LLM_MAX_ITEMS=10

# QBR only — extra guidance for the signals LLM from Drive: Manifest Doc text + optional YAML from the
# executive-summary deck’s signals slide. No effect on slides if BPO_SIGNALS_LLM is off.
# BPO_SIGNALS_LLM_EDITORIAL=true
# BPO_SIGNALS_LLM_DECK_PROMPT=true
# BPO_SIGNALS_LLM_MANIFEST_MAX_CHARS=8000
# BPO_SIGNALS_LLM_SLIDE_PROMPT_MAX_CHARS=2500

# Notable Signals trends: extra Pendo visitor-window pulls → report.signals_trends_display as the gray
# banner on the first Notable Signals page, plus trend strings for the signals LLM. Adds latency (especially with prior period).
# BPO_SIGNALS_TRENDS=true
# Second full-period visitor aggregate (heavy); default off — enable for prior-window / QoQ-style comparisons.
# BPO_SIGNALS_TRENDS_PRIOR_PERIOD=false
# Optional comparison horizons (each adds work when true and the quarter is long enough).
# BPO_SIGNALS_TRENDS_WOW=true
# BPO_SIGNALS_TRENDS_MOM=false
# BPO_SIGNALS_TRENDS_YOY=false
# Per-trend HTTP read timeout (seconds); main Pendo pipeline uses a separate longer timeout.
# BPO_SIGNALS_TRENDS_TIMEOUT=75

# LLM — required for the agent. Also used when BPO_SIGNALS_LLM or QBR adapt/hints call a model.
# LLM_PROVIDER=gemini or openai. If both API keys are set, this chooses which provider runs.
# Defaults: gemini when GEMINI_API_KEY is set, otherwise openai.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# Google — Slides/Drive via service account JSON; optional user impersonation for quota/ownership.
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# Default parent folder for generated presentations (when a command does not pass another folder).
GOOGLE_DRIVE_FOLDER_ID=
# Domain-wide delegation: act as this user so new files count against their Drive quota (not the SA’s).
GOOGLE_DRIVE_OWNER_EMAIL=
# Hydrate / evaluate: list Slides shared with this Google Group (must match Drive sharing exactly).
GOOGLE_HYDRATE_INTAKE_GROUP=
# QBR "Generator" folder: contains "[Template] - Quarterly Business Review" and Prompts/Manifest Doc.
# Under it, subfolder "Cache" holds portfolio JSON, Pendo preload slice JSON, and data_field_synonyms.json
# (unless BPO_PORTFOLIO_SNAPSHOT_FOLDER_ID points elsewhere). Rename old "Portfolio cache" to "Cache" in Drive
# or set BPO_PORTFOLIO_SNAPSHOT_FOLDER_ID to keep using the previous folder.
GOOGLE_QBR_GENERATOR_FOLDER_ID=
# Optional: override Drive folder for portfolio + Pendo preload caches + synonyms (folder id).
# BPO_PORTFOLIO_SNAPSHOT_FOLDER_ID=
# Max age (hours) for portfolio snapshot and Pendo preload JSON when reading from Drive (default 168 = 7d).
# BPO_PORTFOLIO_SNAPSHOT_MAX_AGE_HOURS=168
# After max age, weekday runs may still reuse Drive until the next Sat/Sun refresh (see BPO_DRIVE_CACHE_*).
# Hard cap (hours) for that stale weekday reuse — then refresh any day (default 336 = 14d).
# BPO_DRIVE_CACHE_STALE_MAX_AGE_HOURS=336
# When true (default), Drive writes for large caches run on weekends only; weekdays skip overwrite.
# Set false for legacy behavior (write after every fresh Pendo pull).
# BPO_DRIVE_CACHE_WEEKEND_SCHEDULE=false
# Skip reading those caches for this process (still writes after fresh Pendo pulls when configured).
# BPO_PORTFOLIO_SNAPSHOT_FORCE_REFRESH=1
# Extra Pendo customer prefixes to omit from portfolio/cohort rollup (comma-separated). cohorts.yaml ``exclude:`` is also applied.
# BPO_PORTFOLIO_EXCLUDE_CUSTOMERS=Automated
# Never read/write Pendo preload slice files on Drive (portfolio snapshot / synonyms unchanged).
# BPO_PENDO_PRELOAD_CACHE_DISABLED=1
# QBR customer bundles land under `{ISO-date} - Output` here; if empty, uses GOOGLE_DRIVE_FOLDER_ID.
GOOGLE_QBR_OUTPUT_PARENT_ID=

# Hydrate: max slides to classify and copy from the source deck (0 = no cap).
HYDRATE_MAX_SLIDES=10
# After hydrate, remove the intake group permission from the source deck (recommended for clean ACLs).
# HYDRATE_REMOVE_INTAKE_GROUP_PERMISSION=true
# decks --scan-fields: max slides to scan (0 = all). If unset, HYDRATE_MAX_SLIDES is used.
# SCAN_MAX_SLIDES=0

# Console verbosity for the `bpo` logger (DEBUG, INFO, WARNING, …).
# LOG_LEVEL=INFO

# JIRA Cloud (read-only). Fills report.jira — Support Health & SLA, ticket lists, engineering pipeline slides;
# also feeds cross-source / signal hints when those paths run.
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# Salesforce JWT (Connected App + integration user + private key). When configured, enriches the health
# report (account match, renewal, CRM context) and enables salesforce comprehensive deck types.
# Loaded by src/config.py: SF_LOGIN_URL, SF_CONSUMER_KEY, SF_USERNAME, and SF_PRIVATE_KEY or SF_PRIVATE_KEY_PATH
# Optional: cache SOQL / describe / COUNT responses (default 48 hours). Set TTL to 0 or use DISABLED to turn off.
# BPO_SALESFORCE_CACHE_TTL_HOURS=48
# BPO_SALESFORCE_CACHE_DISABLED=true
# BPO_SALESFORCE_CACHE_FORCE_REFRESH=true
SF_LOGIN_URL=https://login.salesforce.com
SF_CONSUMER_KEY=
SF_USERNAME=
SF_PRIVATE_KEY_PATH=server.key
# Alternative to path: paste PEM body (quoted/multiline). Use one of SF_PRIVATE_KEY or SF_PRIVATE_KEY_PATH.
# SF_PRIVATE_KEY=

# Connected App labels — not read by BPO; optional notes for you or external tooling.
# SF_APP_NAME=
# SF_CONSUMER_SECRET=
# SF_CALLBACK_URL=https://login.salesforce.com/services/oauth2/success
