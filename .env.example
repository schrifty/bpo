# Pendo API 
PENDO_INTEGRATION_KEY=

# LLM — set one or both keys; use LLM_PROVIDER to choose (gemini or openai).
# Defaults to gemini if GEMINI_API_KEY is set, otherwise openai.
# LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_DRIVE_FOLDER_ID=

# Your Google email (folder owner) - enables domain-wide delegation so files use your 4.49TB quota
GOOGLE_DRIVE_OWNER_EMAIL=

JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Salesforce (JWT Bearer Flow — optional)
# SF_LOGIN_URL: https://login.salesforce.com (prod) or https://test.salesforce.com (sandbox)
# SF_CONSUMER_KEY: Connected App Consumer Key (Client ID)
# SF_USERNAME: Integration user username (e.g. leandna.integration@leandna.com)
# SF_PRIVATE_KEY: PEM string of server.key, or use SF_PRIVATE_KEY_PATH
SF_LOGIN_URL=
SF_CONSUMER_KEY=
SF_USERNAME=
# SF_PRIVATE_KEY=
# SF_PRIVATE_KEY_PATH=path/to/server.key