# Copy to .env and fill in values. Defaults for optional keys live in src/config.py unless noted below.

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Console verbosity for the `bpo` logger: DEBUG, INFO, WARNING, ERROR.
# LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Pendo
# -----------------------------------------------------------------------------
# Required for Pendo-backed data: customer health, QBR, benchmarks, portfolio snapshots, and related slides.
PENDO_INTEGRATION_KEY=

# API base URL (change only for non-standard Pendo hosts).
# PENDO_BASE_URL=https://app.pendo.io/api/v1

# Optional caps on tool/agent result size (0 = no limit).
# PENDO_MAX_RESULTS=0
# PENDO_MAX_OUTPUT_CHARS=0

# Comma-separated customer name prefixes to merge with config/portfolio_exclude_prefixes.yaml for portfolio rollup.
# BPO_PORTFOLIO_EXCLUDE_CUSTOMERS=ExampleNonCustomer

# Parallelism for portfolio aggregation (default 8).
# BPO_PORTFOLIO_PARALLEL_WORKERS=8

# Portfolio customer list: auto (Salesforce Customer Entity rollup when SF is configured; else Pendo prefixes), salesforce, or pendo.
# BPO_PORTFOLIO_CUSTOMER_SOURCE=auto

# -----------------------------------------------------------------------------
# Feature adoption & Notable Signals (optional toggles)
# -----------------------------------------------------------------------------
# Extra Pendo work for Feature Adoption slide narrative and cross-source context. Off unless true.
# BPO_FEATURE_ADOPTION_INSIGHTS=true

# Support review deck: generate the "Notable" slide bullets with an LLM (digest of Jira in this run). Off to use YAML-only.
# BPO_SUPPORT_NOTABLE_LLM=true

# LLM pass on Notable Signals after heuristics. Off unless true.
# BPO_SIGNALS_LLM=true
# BPO_SIGNALS_LLM_MAX_ITEMS=10

# Template QBR: allow the pipeline to create or modify config/qbr_mappings.yaml (bootstrap + append unmapped sources). Off by default — set to 1 so manual YAML edits are never overwritten unless you opt in.
# BPO_QBR_MAPPINGS_WRITE=1
#
# Legacy: if BPO_QBR_MAPPINGS_WRITE is unset, BPO_QBR_MAPPINGS_AUTOWRITE=true also enables those writes.
# BPO_QBR_MAPPINGS_AUTOWRITE=true
#
# If qbr_mappings.yaml is missing and writes are off, add it manually or set BPO_QBR_MAPPINGS_WRITE=1 so the next QBR can bootstrap from a slide walk.

# QBR only: extra guidance from Drive (`qbr_slide_list` + signals slide YAML). No effect if BPO_SIGNALS_LLM is off.
# BPO_SIGNALS_LLM_EDITORIAL=true
# BPO_SIGNALS_LLM_DECK_PROMPT=true
# BPO_SIGNALS_LLM_MANIFEST_MAX_CHARS=8000
# BPO_SIGNALS_LLM_SLIDE_PROMPT_MAX_CHARS=2500

# Trend banner + LLM trend strings (adds Pendo calls and latency).
# BPO_SIGNALS_TRENDS=true
# BPO_SIGNALS_TRENDS_PRIOR_PERIOD=false
# BPO_SIGNALS_TRENDS_WOW=true
# BPO_SIGNALS_TRENDS_MOM=false
# BPO_SIGNALS_TRENDS_YOY=false
# BPO_SIGNALS_TRENDS_TIMEOUT=75

# -----------------------------------------------------------------------------
# LLM provider (agent, optional signals, QBR adapt)
# -----------------------------------------------------------------------------
# gemini | openai. If unset, defaults to gemini when GEMINI_API_KEY is set, otherwise openai.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# All-customers export (`decks --export`): default --max-bytes 0 (no size cap); §4 CS Report = top N by ARR (default 20).
# BPO_LLM_EXPORT_MAX_BYTES=0
# BPO_LLM_EXPORT_CSR_TOP_N=20
# All-customers export (`decks --export`): §7 risk insights always run (tuning below).
# BPO_LLM_EXPORT_RISK_CUSTOMER_CAP=40
# BPO_LLM_EXPORT_RISK_BATCH_SIZE=10
# All-customers export: per-label Salesforce comprehensive (§3c). Set false to skip CRM row fetches.
# BPO_LLM_EXPORT_SF_COMPREHENSIVE=true
# BPO_LLM_EXPORT_SF_COMPREHENSIVE_ROW_LIMIT=75
# BPO_LLM_EXPORT_SF_COMPREHENSIVE_CUSTOMER_CAP=
# Per-customer SF comprehensive uses Drive integration cache (same as salesforce_comprehensive decks).
# BPO_INTEGRATION_DRIVE_CACHE_DISABLED=false
# BPO_INTEGRATION_DRIVE_CACHE_FORCE_REFRESH=false

# -----------------------------------------------------------------------------
# Google — Drive, Slides, QBR, hydrate
# -----------------------------------------------------------------------------
# Path to the service account JSON with Slides + Drive scopes.
# Relative paths resolve from the repo root (e.g. project/bpo/service-account.json).
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Domain-wide delegation: act as this user so new files use their quota (recommended).
GOOGLE_DRIVE_OWNER_EMAIL=

# Required: QBR Generator folder (Prompts/, decks/, slides/, chart-data/, individual deck outputs, Output/, etc.).
GOOGLE_QBR_GENERATOR_FOLDER_ID=

# Optional: folder that contains only the QBR Slides template. If unset, the template is resolved under GOOGLE_QBR_GENERATOR_FOLDER_ID.
GOOGLE_QBR_TEMPLATE_FOLDER_ID=

# Exact Google Slides document title for the QBR template on Drive. If unset, defaults to BPO [Template] Executive Business Review [QBR].
QBR_TEMPLATE_FILE_NAME=

# Optional: parent folder for `{ISO-date} - Output` bundles. Default is folder "Output" under GOOGLE_QBR_GENERATOR_FOLDER_ID.
GOOGLE_QBR_OUTPUT_PARENT_ID=

# Hydrate / evaluate: Google Group email whose shared Slides are intake candidates (must match Drive sharing exactly).
GOOGLE_HYDRATE_INTAKE_GROUP=

# Portfolio snapshot + Pendo preload cache + synonyms JSON: optional override folder. Default is subfolder "Cache" under GOOGLE_QBR_GENERATOR_FOLDER_ID.
# BPO_PORTFOLIO_SNAPSHOT_FOLDER_ID=
# Pendo read/preload caches: in-process slices plus Drive JSON preload/portfolio snapshots.
# BPO_PENDO_CACHE_TTL_SECONDS=120
# BPO_PENDO_CACHE_DISABLED=true

# IANA timezone for weekend/weekday cache refresh and QBR calendar helpers (default UTC).
# BPO_PORTFOLIO_SNAPSHOT_CALENDAR_TZ=America/New_York

# -----------------------------------------------------------------------------
# Hydrate / evaluate
# -----------------------------------------------------------------------------
# Max slides to classify and copy from the source deck (0 = no cap).
HYDRATE_MAX_SLIDES=10

# After hydrate, remove the intake group permission from the source deck.
# HYDRATE_REMOVE_INTAKE_GROUP_PERMISSION=true
# Hydrate: append JSONL mapping audit to matching.log (set 0 to disable)
# BPO_MATCHING_LOG=1
# Optional path (default: matching.log in repo root)
# BPO_MATCHING_LOG_PATH=

# -----------------------------------------------------------------------------
# JIRA Cloud (read-only)
# -----------------------------------------------------------------------------
# Support, SLA, engineering pipeline slides, and cross-source signals when those paths run.
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# -----------------------------------------------------------------------------
# GitHub (optional)
# -----------------------------------------------------------------------------
# When set, deck preflight calls the GitHub API (GET /user). Use a classic PAT or fine-grained token
# with minimal scopes until specific features (issues, releases) are enabled.
# GITHUB_TOKEN=
# GITHUB_API_BASE_URL=https://api.github.com

# -----------------------------------------------------------------------------
# Salesforce (JWT Bearer Flow — optional)
# -----------------------------------------------------------------------------
# Setup walkthrough: docs/SETUP/SALESFORCE_SETUP.md
# Enriches health reports and enables Salesforce comprehensive deck types when configured.
SF_LOGIN_URL=https://login.salesforce.com
SF_CONSUMER_KEY=
SF_USERNAME=
SF_PRIVATE_KEY_PATH=server.key
# Alternative: PEM string (use SF_PRIVATE_KEY or SF_PRIVATE_KEY_PATH, not both).
# SF_PRIVATE_KEY=

# Salesforce read cache (SOQL, describe, COUNT). TTL in hours; 0 disables. Set DISABLED to turn cache off.
# BPO_SALESFORCE_CACHE_TTL_HOURS=48
# BPO_SALESFORCE_CACHE_DISABLED=true

# Optional: Account field API name for Ultimate Parent (e.g. Ultimate_Parent_Account__c).
# SF_ACCOUNT_ULTIMATE_PARENT_LOOKUP=
# Customer Entity operational / factory go-live date (Account API name). Default: Effective_Date_of_Order__c
# SF_ACCOUNT_FACTORY_START_DATE_FIELD=Effective_Date_of_Order__c

# Connected App metadata — not read by BPO; optional notes for you or external tooling.
# SF_APP_NAME=
# SF_CONSUMER_SECRET=
# SF_CALLBACK_URL=https://login.salesforce.com/services/oauth2/success

# -----------------------------------------------------------------------------
# LeanDNA Data API (optional; setup: docs/SETUP/LEANDNA_SETUP.md; OpenAPI: scripts/fetch_leandna_swagger.py)
# -----------------------------------------------------------------------------
# Optional: Staging | Production | CI — when set, only prefixed vars below are used (unprefixed ignored).
# Any other non-empty value disables LeanDNA Data API until EXECUTION_ENV is fixed or unset.
# EXECUTION_ENV=Staging
# EXECUTION_ENV=Production
# EXECUTION_ENV=CI
# Production and CI: LeanDNA POST/PUT/DELETE are blocked (read-only). Opt-in override (logged):
# BPO_ALLOW_PRODUCTION_MUTATIONS=true
#
# Staging (prefix ST_) — example:
# ST_LEANDNA_DATA_API_BASE_URL=https://app.staging.leandna.com/api
# ST_LEANDNA_DATA_API_BEARER_TOKEN=
# ST_LEANDNA_DATA_API_COOKIE=
# ST_LEANDNA_DATA_API_ORIGIN=https://app.staging.leandna.com
# ST_LEANDNA_DATA_API_REFERER=https://app.staging.leandna.com/application/
#
# Production / CI (prefix PR_) — example:
# PR_LEANDNA_DATA_API_BASE_URL=https://app.leandna.com/api
# PR_LEANDNA_DATA_API_BEARER_TOKEN=
# PR_LEANDNA_DATA_API_COOKIE=
# PR_LEANDNA_DATA_API_ORIGIN=https://app.leandna.com
# PR_LEANDNA_DATA_API_REFERER=https://app.leandna.com/application/
#
# Legacy (EXECUTION_ENV unset): unprefixed vars only.
# Must match the environment where the token or browser session was issued (401 if wrong host).
# LEANDNA_DATA_API_BASE_URL=https://app.leandna.com/api
# Staging example (confirm in LeanDNA admin): https://app.staging.leandna.com/api
# LEANDNA_DATA_API_BEARER_TOKEN=
# If Bearer returns 401 but the web app works: paste Cookie header from DevTools on a /api/data/ request.
# LEANDNA_DATA_API_COOKIE=
# LEANDNA_DATA_API_ORIGIN=https://app.leandna.com
# LEANDNA_DATA_API_REFERER=https://app.leandna.com/application/

# -----------------------------------------------------------------------------
# LeanDNA classic app API (session — kpi/update-kpi style; no Data API Bearer)
# Log into https://app.leandna.com (or staging), copy LDNASESSIONID from DevTools Cookie.
# Scripts: get-metrics, get-metrics-data, set-metric-entry, delete-metric-entry (bin/*-app wrappers)
# LEANDNA_APP_API_SERVER=https://app.staging.leandna.com
# LEANDNA_APP_SESSION_ID=
# test-script: browser SSO (pip install -r requirements-dev.txt && playwright install chromium)
# LEANDNA_APP_EMAIL=you@company.com
# Complete Google MFA in the browser window (password not auto-typed by default).
# BPO_LEANDNA_SSO_AUTO_GOOGLE=true   # optional: auto-type password (may trigger laptop MFA)
# LEANDNA_APP_PASSWORD=
# LEANDNA_APP_TOTP_SECRET=
# LEANDNA_APP_SSO_CUSTOMER_ID=   # optional; skip email form when known
# BPO_LEANDNA_PLAYWRIGHT_STORAGE_STATE=.cache/leandna-sso-state.json
# LEANDNA_APP_USERNAME=
# Or paste full Cookie header (must include LDNASESSIONID=):
# LEANDNA_APP_COOKIE=
# LEANDNA_APP_FACTORY_NDX=416
# LEANDNA_APP_METRICS_VIEW_QUERY=category=Engineering%2CData%20Integration&entryType=Manual&activated=active
# metricOwner filter for get-my-metrics (display name from whoami):
# LEANDNA_APP_METRIC_OWNER=Marc Schriftman
# LEANDNA_APP_USER_NDX=29036
# Numeric ndx is usually wrong for Metrics/View (kpi id ≠ your metricOwner label).

# -----------------------------------------------------------------------------
# Advanced (optional; see src/slides_api.py, src/jira_client.py)
# -----------------------------------------------------------------------------
# Slides API batching / throttling.
# BPO_SLIDES_WRITE_INTERVAL_SEC=1.05
# BPO_SLIDES_BATCH_UPDATE_RETRIES=12
# BPO_SLIDES_BATCH_CHUNK_SIZE=

# JIRA client tuning and Help JIRA limits.
# BPO_JIRA_PARALLEL_WORKERS=3
# BPO_JSM_ORG_CACHE_TTL_S=900
# BPO_HELP_JIRA_BODY_MAX=750
# BPO_HELP_JIRA_METRICS_MAX=2000
# BPO_JIRA_SKIP_JSM_ORG_FUZZY=true
# get-dev-cycle-times: comma-separated issuetype names to exclude (SUT/Sub-task kept by default)
# BPO_CYCLE_TIME_EXCLUDE_ISSUE_TYPES=Epic,Hypercare
# BPO_CYCLE_TIME_OUTLIER_SIGMA=4
